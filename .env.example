# --- Core paths ---
GA4_PROPERTY_ID=
GOOGLE_APPLICATION_CREDENTIALS=/path/to/actio-ga4.json
DB_PATH=marketing_data.db

# --- Reports backend ---
# Tryb VPS: zapis raportów do katalogu /md-reports/. Pomiń żeby używać Obsidian CLI lokalnie.
MD_REPORTS_DIR=
# Public URL Chainlit panelu (używany w mailach + Pushover linkach)
CHAINLIT_BASE_URL=

# --- Tryb lokalny (Obsidian) ---
OBSIDIAN_REPORTS_PATH=projects/actio-marketing-reports
OBSIDIAN_VAULT_NAME=vault

# --- Google Ads ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_OAUTH_CLIENT_ID=
GOOGLE_ADS_OAUTH_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# --- LLM via OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-opus-4.7

# --- Pushover ---
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=

# --- Gmail SMTP (raporty email) ---
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_FROM_NAME=Actio Marketing Reports
REPORT_RECIPIENTS_CMO=
REPORT_RECIPIENTS_CEO=
