# Profil env dla raportu SENDLY (BRAND=sendly).
# Kopiuj jako .env w checkoutcie /opt/sendly-marketing-panel na VPS ra.
# Sekcje "REUZYWANE Z KONTA" = te same wartosci co actio (jedno konto Google/OpenRouter/Gmail/Pushover).

# --- selektor marki ---
BRAND=sendly

# --- SPECYFICZNE DLA SENDLY (zmien) ---
GA4_PROPERTY_ID=540473438   # sendly.link (konto "SENDLY OK"); potwierdz ze data stream = G-FLRPGGJ9G9
GOOGLE_ADS_CUSTOMER_ID=2556473852   # SYNTELL S.A. (255-647-3852) — spolka matka Sendly/Actio
DB_PATH=/opt/sendly-marketing-panel/sendly_marketing.db
MD_FULL_DIR=/opt/sendly-marketing-panel/md-reports-full
MD_REPORTS_DIR=/opt/sendly-marketing-panel/md-reports
OBSIDIAN_REPORTS_PATH=projects/sendly-marketing-reports
GMAIL_FROM_NAME=Sendly Marketing Reports

# --- Cloudflare (sendly.link na CF Pages) — konektor AI Crawl Control + edge HTTP health ---
CLOUDFLARE_API_TOKEN=       # TODO: token read-only (Account Analytics:Read + Zone Analytics:Read)
CLOUDFLARE_ACCOUNT_ID=      # TODO: Account ID (CF dashboard)
CLOUDFLARE_ZONE_ID=         # TODO: Zone ID strefy sendly.link (CF Overview)

# --- ODBIORCY ---
# DO ODWOLANIA: oba raporty sendly ida TYLKO do Tomka. Huberta wpinamy pozniej jednym ruchem.
REPORT_RECIPIENTS_CMO=tlebioda@gmail.com
REPORT_RECIPIENTS_CEO=tlebioda@gmail.com
# Docelowo (na sygnal Tomka): REPORT_RECIPIENTS_CEO=hubert.porebski@actio.pl
PUSHOVER_USER_KEY_PANEL=    # pusty do czasu wpiecia Huberta (klucz Pushover Huberta)

# --- REUZYWANE Z KONTA (te same wartosci co w .env actio) ---
GOOGLE_APPLICATION_CREDENTIALS=/opt/sendly-marketing-panel/.gcp/actio-ga4.json  # ten sam SA; musi miec dostep do GA4/GSC sendly
GOOGLE_ADS_LOGIN_CUSTOMER_ID=       # MCC — jak actio (do potwierdzenia czy siega 255-647-3852)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_OAUTH_CLIENT_ID=
GOOGLE_ADS_OAUTH_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-fable-5
OPENROUTER_FALLBACK_MODEL=anthropic/claude-opus-4.8
GMAIL_USER=
GMAIL_APP_PASSWORD=
PUSHOVER_API_TOKEN=
PUSHOVER_USER_KEY=          # Tomek (grupa CMO + emergency alerty)
